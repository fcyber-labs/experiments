# ============================================
# RAG Pipeline - Environment Variables Template
# Copy this to .env and fill in your values
# ============================================

# --------------------------------------------
# OpenAI Configuration
# --------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
# Which embedding model to use
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --------------------------------------------
# Slack Notifications
# --------------------------------------------
# Get webhook URL from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# --------------------------------------------
# AWS Configuration (Optional - for S3 sources)
# --------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1

# S3 bucket containing documents
RAG_S3_BUCKET=your-company-docs-bucket
RAG_S3_PREFIX=knowledge-base/

# --------------------------------------------
# Airflow Configuration
# --------------------------------------------
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__SECRET_KEY=change-this-to-random-secret-key

# --------------------------------------------
# Redis Configuration
# --------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# Document hash TTL (seconds) - 30 days default
REDIS_HASH_TTL=2592000

# --------------------------------------------
# Qdrant Configuration
# --------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
# Collection names
QDRANT_STAGING_COLLECTION=knowledge_base_staging
QDRANT_PRODUCTION_COLLECTION=knowledge_base

# --------------------------------------------
# MLflow Configuration
# --------------------------------------------
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=rag_refresh_pipeline

# --------------------------------------------
# Prometheus Configuration
# --------------------------------------------
PROMETHEUS_PUSHGATEWAY=prometheus-pushgateway:9091
PROMETHEUS_URL=http://prometheus:9090

# --------------------------------------------
# Pipeline Configuration
# --------------------------------------------
# Chunking parameters
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50

# Evaluation threshold (minimum acceptable recall@5)
RAG_EVAL_THRESHOLD=0.75

# Document expiration (days, 0 = never expire)
RAG_DOCUMENT_EXPIRATION_DAYS=365

# Hybrid search weight (0.0-1.0, 0.3 = 30% BM25, 70% vector)
RAG_BM25_WEIGHT=0.3

# --------------------------------------------
# Cost Management
# --------------------------------------------
# Monthly budget limit in USD
RAG_COST_BUDGET_MONTHLY=50.0

# Alert when cost reaches this percentage of budget
RAG_COST_ALERT_THRESHOLD=0.80

# --------------------------------------------
# Advanced Features
# --------------------------------------------
# Enable/disable features
RAG_USE_HYBRID_SEARCH=true
RAG_USE_QUERY_REWRITING=true
RAG_USE_RERANKING=true

# Reranker model
RAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Query rewriting strategy (llm_based or rule_based)
RAG_QUERY_REWRITE_STRATEGY=rule_based

# --------------------------------------------
# Metadata DB (new — separate from Airflow's own DB)
# --------------------------------------------
RAG_METADATA_DB_HOST=postgres
RAG_METADATA_DB_PORT=5432
RAG_METADATA_DB_NAME=rag_metadata
RAG_METADATA_DB_USER=airflow
RAG_METADATA_DB_PASSWORD=airflow