{
  "dashboard": {
    "title": "RAG Pipeline Health",
    "tags": ["rag", "pipeline", "embeddings"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Documents Processed (Total)",
        "type": "stat",
        "targets": [
          {
            "expr": "rag_documents_processed_total",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 0
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
                  "color": "green"
                }
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Chunks Created (Total)",
        "type": "stat",
        "targets": [
          {
            "expr": "rag_chunks_created_total",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 0
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
                  "color": "blue"
                }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Current Recall@5",
        "type": "gauge",
        "targets": [
          {
            "expr": "rag_eval_recall_at_5",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 12,
          "y": 0
        },
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": 0,
                  "color": "red"
                },
                {
                  "value": 0.5,
                  "color": "yellow"
                },
                {
                  "value": 0.75,
                  "color": "green"
                }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Dedup Cache Hit Rate",
        "type": "gauge",
        "targets": [
          {
            "expr": "rag_dedup_cache_hit_rate",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 18,
          "y": 0
        },
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "unit": "percentunit",
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": 0,
                  "color": "green"
                },
                {
                  "value": 0.5,
                  "color": "yellow"
                },
                {
                  "value": 0.9,
                  "color": "red"
                }
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Retrieval Quality Over Time",
        "type": "graph",
        "targets": [
          {
            "expr": "rag_eval_recall_at_5",
            "refId": "A",
            "legendFormat": "Recall@5"
          },
          {
            "expr": "rag_eval_mrr",
            "refId": "B",
            "legendFormat": "MRR"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 4
        },
        "yaxes": [
          {
            "label": "Score",
            "min": 0,
            "max": 1
          }
        ],
        "lines": true,
        "fill": 1,
        "linewidth": 2
      },
      {
        "id": 6,
        "title": "Documents Processed Per Run",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(rag_documents_processed_total[5m])",
            "refId": "A",
            "legendFormat": "Documents/min"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 4
        },
        "yaxes": [
          {
            "label": "Documents",
            "min": 0
          }
        ],
        "lines": true,
        "fill": 1,
        "linewidth": 2
      },
      {
        "id": 7,
        "title": "Embedding Latency",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(rag_embedding_latency_seconds_sum[5m]) / rate(rag_embedding_latency_seconds_count[5m])",
            "refId": "A",
            "legendFormat": "Avg Latency"
          }
        ],
        "gridPos": {
          "h": 6,
          "w": 12,
          "x": 0,
          "y": 12
        },
        "yaxes": [
          {
            "label": "Seconds",
            "min": 0
          }
        ],
        "lines": true,
        "fill": 1,
        "linewidth": 2
      },
      {
        "id": 8,
        "title": "Vector Upsert Latency",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(rag_upsert_latency_seconds_sum[5m]) / rate(rag_upsert_latency_seconds_count[5m])",
            "refId": "A",
            "legendFormat": "Avg Latency"
          }
        ],
        "gridPos": {
          "h": 6,
          "w": 12,
          "x": 12,
          "y": 12
        },
        "yaxes": [
          {
            "label": "Seconds",
            "min": 0
          }
        ],
        "lines": true,
        "fill": 1,
        "linewidth": 2
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m"]
    }
  }
}