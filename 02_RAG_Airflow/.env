# ============================================
# RAG Pipeline - Environment Variables
# Copy this to .env and fill in your values
# ============================================

# --------------------------------------------
# OpenAI Configuration
# --------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# --------------------------------------------
# Slack Notifications
# --------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# --------------------------------------------
# AWS Configuration (Optional - for S3 sources)
# --------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1

# --------------------------------------------
# Airflow Configuration
# --------------------------------------------
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false

# --------------------------------------------
# Redis Configuration
# --------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# --------------------------------------------
# Qdrant Configuration
# --------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# --------------------------------------------
# MLflow Configuration
# --------------------------------------------
MLFLOW_TRACKING_URI=http://mlflow:5000

# --------------------------------------------
# Prometheus Configuration
# --------------------------------------------
PROMETHEUS_PUSHGATEWAY=prometheus-pushgateway:9091

# --------------------------------------------
# Pipeline Configuration
# --------------------------------------------
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EVAL_THRESHOLD=0.75

# --------------------------------------------
# Document Sources
# --------------------------------------------
RAG_S3_BUCKET=your-company-docs-bucket
RAG_S3_PREFIX=knowledge-base/

# --------------------------------------------
# Metadata DB (new — separate from Airflow's own DB)
# --------------------------------------------
RAG_METADATA_DB_HOST=postgres
RAG_METADATA_DB_PORT=5432
RAG_METADATA_DB_NAME=rag_metadata
RAG_METADATA_DB_USER=airflow
RAG_METADATA_DB_PASSWORD=airflow



# SLACK

SLACK_WEBHOOK_URL = https://hooks.slack.com/services/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